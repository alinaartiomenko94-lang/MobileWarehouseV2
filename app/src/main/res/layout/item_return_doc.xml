<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvContractor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Контрагент"
            android:textStyle="bold"/>

        <!-- Строка: ТТН (плашка) + Статус (бейдж) -->
        <LinearLayout
            android:id="@+id/rowBadges"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- Плашка ТТН -->
            <TextView
                android:id="@+id/tvInvoiceBadge"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ТТН № 12345"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_badge_invoice"/>

            <!-- Бейдж статуса -->
            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="В РАБОТЕ"
                android:textStyle="bold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_badge_status_inwork"/>
        </LinearLayout>

        <!-- Дата документа + тип -->
        <TextView
            android:id="@+id/tvDocInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="20.01.2026 • Возвратная накладная"
            android:layout_marginTop="8dp"/>

        <!-- Приёмка -->
        <TextView
            android:id="@+id/tvAcceptance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Приёмка: 21.01.2026"
            android:layout_marginTop="4dp"/>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetails"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Детали"
                android:textAllCaps="false"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnItems"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Список товара"
                android:textAllCaps="false"/>
        </LinearLayout>

        <!-- Детали (скрыты по умолчанию) -->
        <LinearLayout
            android:id="@+id/layoutDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvTotalQty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Всего: 0 шт."
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvTotalDef"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Брак: 0 шт."
                android:layout_marginTop="4dp"
                android:textStyle="bold"/>
        </LinearLayout>


    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
